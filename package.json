{
  "name": "blacktower",
  "version": "1.1.0",
  "description": "Agent orchestration plugin for OpenCode",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    }
  },
  "bin": {
    "blacktower": "./dist/cli/index.js"
  },
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "license": "MIT",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "ai",
    "agents",
    "orchestration",
    "llm",
    "claude",
    "gpt",
    "gemini"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/blacktower/blacktower"
  },
  "bugs": {
    "url": "https://github.com/blacktower/blacktower/issues"
  },
  "homepage": "https://github.com/blacktower/blacktower#readme",
  "files": [
    "dist",
    "src/skills",
    "scripts/generate_skill_index.py",
    "scripts/validate-hub.sh",
    "scripts/audit_skills.py",
    "scripts/hub_doctor.py",
    "apps/control-center-web/dist",
    "blacktower.schema.json",
    "custom-agent.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:plugin": "bun build src/index.ts src/tui.ts --outdir dist --target node --format esm --external @ast-grep/napi --external @opencode-ai/plugin --external @opencode-ai/sdk --external @opentui/core --external @opentui/solid --external jsdom --external zod",
    "build:cli": "bun build src/cli/index.ts --outdir dist/cli --target node --format esm --external @ast-grep/napi --external @opencode-ai/plugin --external @opencode-ai/sdk --external @opentui/core --external jsdom --external zod",
    "build:web": "bun run --filter @blacktower/control-center-web build",
    "build": "bun run build:web && bun run build:plugin && bun run build:cli && tsc --emitDeclarationOnly && bun run generate-schema",
    "prepare": "bun run build",
    "contributors:add": "all-contributors add",
    "contributors:check": "all-contributors check",
    "contributors:generate": "all-contributors generate",
    "generate-schema": "bun run scripts/generate-schema.ts",
    "verify:release": "bun run scripts/verify-release-artifact.ts",
    "verify:host-smoke": "bun run scripts/verify-opencode-host-smoke.ts",
    "bootstrap": "bun run src/cli/index.ts bootstrap",
    "setup": "bun run src/cli/index.ts setup",
    "preview": "bun run src/cli/index.ts preview",
    "update": "bun run src/cli/index.ts update",
    "repair": "bun run src/cli/index.ts repair",
    "control-center": "bun run src/cli/index.ts control-center",
    "control-center:web": "bun run src/cli/index.ts control-center-web",
    "control-center:web:api": "bun run src/cli/index.ts control-center-web --api-only",
    "control-center:web:dev": "bun run --filter @blacktower/control-center-web dev",
    "test:web": "bun run --filter @blacktower/control-center-web test",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check --write .",
    "check:ci": "biome check .",
    "dev": "bun run build && opencode",
    "prepublishOnly": "bun run build",
    "release:patch": "npm version patch && git push --follow-tags && npm publish",
    "release:minor": "npm version minor && git push --follow-tags && npm publish",
    "release:major": "npm version major && git push --follow-tags && npm publish"
  },
  "dependencies": {
    "@ast-grep/cli": "^0.42.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@opencode-ai/plugin": "^1.3.17",
    "@opencode-ai/sdk": "^1.3.17",
    "jsdom": "^26.1.0",
    "lru-cache": "^11.3.3",
    "turndown": "^7.2.4"
  },
  "optionalDependencies": {
    "@opentui/core": "^0.2.16",
    "@opentui/solid": "^0.2.16"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.6.1",
    "@types/turndown": "^5.0.6",
    "all-contributors-cli": "^6.26.1",
    "bun-types": "1.3.12",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "trustedDependencies": [
    "@ast-grep/cli"
  ]
}

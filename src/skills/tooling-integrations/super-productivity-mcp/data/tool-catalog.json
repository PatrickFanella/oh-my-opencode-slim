    {
      "mcpName": "clear_schedule_for_day",
      "action": "task.clearScheduleForDay",
      "description": "Clear plannedAt for tasks planned on a local YYYY-MM-DD, optionally clearing matching dueDay values. Use dryRun:true to preview changed tasks first.",
      "inputSchema": {
        "type": "object",
        "properties": {

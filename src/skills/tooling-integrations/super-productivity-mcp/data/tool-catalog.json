{
  "protocolVersion": "2.0",
  "resources": [
    { "uri": "sp://projects", "name": "Projects", "description": "All Super Productivity projects", "action": "project.list", "payload": {} },
    { "uri": "sp://tags", "name": "Tags", "description": "All Super Productivity tags", "action": "tag.list", "payload": {} },
    { "uri": "sp://tasks/active", "name": "Active incomplete tasks", "description": "Incomplete active tasks", "action": "task.list", "payload": { "source": "active", "includeDone": false } },
    { "uri": "sp://tasks/archived", "name": "Archived tasks", "description": "Archived tasks when the plugin runtime supports archived reads", "action": "task.listArchived", "payload": {} },
    { "uri": "sp://tasks/current-context", "name": "Current-context tasks", "description": "Tasks from the current Super Productivity context when available", "action": "task.listCurrentContext", "payload": { "includeDone": false } },
    { "uri": "sp://tasks/today", "name": "Tasks planned today", "description": "Incomplete tasks planned for today", "action": "task.list", "payload": { "includeDone": false, "plannedForToday": true } },
    { "uri": "sp://tasks/overdue", "name": "Overdue tasks", "description": "Incomplete tasks with due dates before today", "action": "task.list", "payload": { "includeDone": false, "overdue": true } },
    { "uri": "sp://tasks/unscheduled", "name": "Unscheduled active tasks", "description": "Active top-level tasks with no planned date or due date", "action": "task.findUnscheduledActive", "payload": { "topLevelOnly": true } },
    { "uri": "sp://schedule/today", "name": "Today schedule", "description": "Incomplete tasks planned today with concise synthetic metadata", "action": "task.list", "payload": { "includeDone": false, "plannedForToday": true, "includeSynthetic": true, "sortBy": "plannedAt" } },
    { "uri": "sp://schedule/health", "name": "Schedule health", "description": "Schedule hygiene counts and concise task lists", "action": "task.scheduleHealth", "payload": {} },
    { "uri": "sp://counters", "name": "Plugin counters", "description": "All Super Productivity plugin counters when available", "action": "counter.list", "payload": {} }
  ],
  "tools": [
    {
      "mcpName": "create_task",
      "action": "task.create",
      "description": "Create a new task in Super Productivity. Supports short syntax in title: #tag, +project, @due, estimates like 30m or 1h/2h.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "notes": { "type": "string" },
          "projectId": { "type": "string" },
          "project_id": { "type": "string" },
          "parentId": { "type": "string" },
          "parent_id": { "type": "string" },
          "timeEstimate": { "type": "integer", "minimum": 0 },
          "time_estimate": { "type": "integer", "minimum": 0 },
          "tagIds": { "type": "array", "items": { "type": "string" } },
          "tag_ids": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["title"]
      }
    },
    {
      "mcpName": "get_tasks",
      "action": "task.list",
      "description": "List tasks from Super Productivity",
      "inputSchema": {
        "type": "object",
        "properties": {
          "includeDone": { "type": "boolean" },
          "projectId": { "type": "string" },
          "project_id": { "type": "string" },
          "tagId": { "type": "string" },
          "tag_id": { "type": "string" },
          "isDone": { "type": "boolean" },
          "is_done": { "type": "boolean" },
          "isArchived": { "type": "boolean" },
          "is_archived": { "type": "boolean" },
          "search": { "type": "string" },
          "parentsOnly": { "type": "boolean" },
          "parents_only": { "type": "boolean" },
          "overdue": { "type": "boolean" },
          "unscheduled": { "type": "boolean" },
          "plannedForToday": { "type": "boolean" },
          "planned_for_today": { "type": "boolean" },
          "recurringOnly": { "type": "boolean" },
          "recurring_only": { "type": "boolean" },
          "source": { "type": "string", "enum": ["active", "archived", "all"] },
          "includeSynthetic": { "type": "boolean" },
          "include_synthetic": { "type": "boolean" },
          "sortBy": { "type": "string", "enum": ["title", "created", "updated", "dueDay", "plannedAt", "timeEstimate"] },
          "sort_by": { "type": "string", "enum": ["title", "created", "updated", "dueDay", "plannedAt", "timeEstimate"] },
          "sortDirection": { "type": "string", "enum": ["asc", "desc"] },
          "sort_direction": { "type": "string", "enum": ["asc", "desc"] },
          "limit": { "type": "integer", "minimum": 0 },
          "offset": { "type": "integer", "minimum": 0 },
          "fields": { "type": "array", "items": { "type": "string" } }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "tasks": { "type": "array", "items": { "type": "object" } }
        },
        "required": ["tasks"]
      }
    },
    {
      "mcpName": "create_task_with_subtasks",
      "action": "task.createWithSubtasks",
      "description": "Create a parent task and subtasks in one operation. Supports short syntax in parent and subtask titles.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "notes": { "type": "string" },
          "projectId": { "type": "string" },

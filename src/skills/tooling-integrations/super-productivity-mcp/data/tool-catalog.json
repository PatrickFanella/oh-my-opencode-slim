      "inputSchema": {
        "type": "object",
        "properties": {
          "updates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "taskId": { "type": "string" },
                "task_id": { "type": "string" },
                "title": { "type": "string" },
                "notes": { "type": "string" },
                "isDone": { "type": "boolean" },
                "is_done": { "type": "boolean" },
                "dueDay": { "type": ["string", "null"] },
                "due_day": { "type": ["string", "null"] },
                "plannedAt": { "type": ["integer", "null"] },
                "planned_at": { "type": ["integer", "null"] },
                "timeEstimate": { "type": "integer", "minimum": 0 },
                "time_estimate": { "type": "integer", "minimum": 0 },
                "timeSpent": { "type": "integer", "minimum": 0 },
                "time_spent": { "type": "integer", "minimum": 0 },
                "tagIds": { "type": "array", "items": { "type": "string" } },
                "tag_ids": { "type": "array", "items": { "type": "string" } },
                "projectId": { "type": "string" },
                "project_id": { "type": "string" }
              }
            }
          },
          "dryRun": { "type": "boolean", "description": "When true, return diffs and do not call updateTask." },
          "dry_run": { "type": "boolean", "description": "Snake-case alias for dryRun." }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "dryRun": { "type": "boolean" },
          "results": { "type": "array", "items": { "type": "object" } }
        },

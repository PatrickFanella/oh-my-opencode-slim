          "tagIds": { "type": "array", "items": { "type": "string" } },
          "tag_ids": { "type": "array", "items": { "type": "string" } },
          "subtasks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "notes": { "type": "string" },
                "tagIds": { "type": "array", "items": { "type": "string" } },
                "tag_ids": { "type": "array", "items": { "type": "string" } },
                "timeEstimate": { "type": "integer", "minimum": 0 },
                "time_estimate": { "type": "integer", "minimum": 0 }

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "model": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "minItems": 1,
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "variant": {
                    "type": "string"
                  }
                },
                "required": ["id"]
              }
            ]
          }
        }
      ]
    },
    "temperature": {
      "type": "number",
      "minimum": 0,
      "maximum": 2
    },
    "variant": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mcps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "orchestratorPrompt": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["name", "model"],
  "additionalProperties": false,
  "title": "blacktower custom agent definition",
  "description": "Schema for JSON custom agents loaded from blacktower/agents/*.json"
}
